# ---------------------------------------------------------------------------
# CarHub (Spring Boot) — environment reference
# ---------------------------------------------------------------------------
# Spring Boot reads configuration from the OS environment, NOT from this file
# directly. Copy it to `.env`, fill in real values, then export them before
# running, e.g.:
#
#   set -a; source .env; set +a; ./mvnw spring-boot:run
#
# Or configure these as run-configuration env vars in your IDE.
# Every variable below has a safe dev default in application.yml except the
# ones marked REQUIRED, which have no usable default.
# ---------------------------------------------------------------------------

# --- Server ---------------------------------------------------------------
PORT=5001

# --- MongoDB (Spring Data MongoDB) ----------------------------------------
# REQUIRED in any non-local environment. Defaults to a local mongo otherwise.
DB_URL=mongodb://localhost:27017/carhub
# Database name. Only used when DB_URL has no database in its path (e.g. an
# Atlas SRV string ending in "/"). Set to "test" to reuse the Node app's data.
MONGODB_DATABASE=carhub

# --- Redis (rate limiting, token blacklist, booking lock) -----------------
REDIS_URL=redis://localhost:6379

# --- JWT ------------------------------------------------------------------
# REQUIRED in production. Must be >= 32 bytes for HS256. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes

# --- Cloudinary (car image hosting) ---------------------------------------
# REQUIRED to add/update cars (image upload). Read-only car browsing works
# without them.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email provider -------------------------------------------------------
# Selects the EmailProvider strategy bean: "brevo" (HTTP API) or "smtp".
EMAIL_PROVIDER=brevo
EMAIL_SENDER_NAME=CarHub
EMAIL_SENDER_ADDRESS=no-reply@carhub.com

# Used when EMAIL_PROVIDER=brevo
BREVO_API_KEY=

# Used when EMAIL_PROVIDER=smtp (Gmail SMTP shown)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
